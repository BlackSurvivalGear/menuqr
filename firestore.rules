rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin helper function
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admin collection rules
    match /admins/{adminId} {
      allow read: if request.auth != null && (request.auth.uid == adminId || isAdmin());
      allow write: if false; // Admins should be managed manually in Firebase Console as per instructions
    }

    // User profile rules
    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Restaurant profile rules
    match /restaurants/{uid} {
      // Allow public read access for menu display
      allow read: if true || isAdmin();

      // Allow create and update if the user is the owner
      allow create, update: if request.auth != null && request.auth.uid == uid;

      // Explicitly deny delete
      allow delete: if false;
    }

    // Menu Category rules
    match /menuCategories/{categoryId} {
      allow create: if request.auth != null && request.resource.data.restaurantId == request.auth.uid;
      allow read: if (request.auth != null && resource.data.restaurantId == request.auth.uid) || isAdmin();
      allow update, delete: if request.auth != null && resource.data.restaurantId == request.auth.uid;
    }

    // Menu Item rules
    match /menuItems/{itemId} {
      // Allow public read access for menu display
      allow read: if true || isAdmin();

      // Owner write access
      allow create: if request.auth != null && request.resource.data.restaurantId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.restaurantId == request.auth.uid;
    }
  }
}
