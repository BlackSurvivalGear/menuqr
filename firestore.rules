rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin helper function
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admin collection rules
    match /admins/{adminId} {
      allow read: if request.auth != null && (request.auth.uid == adminId || isAdmin());
      allow write: if false; // Admins should be managed manually in Firebase Console as per instructions
    }

    // User profile rules
    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();

      allow create: if request.auth != null && request.auth.uid == userId;

      allow update: if (request.auth != null && request.auth.uid == userId &&
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'subscriptionActivatedAt', 'activatedBy', 'subscriptionExpiry']))
                    || (isAdmin() &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['plan', 'subscriptionActivatedAt', 'activatedBy', 'subscriptionExpiry']));

      allow delete: if isAdmin();
    }

    // Restaurant profile rules
    match /restaurants/{uid} {
      // Allow public read access for menu display
      allow read: if true || isAdmin();

      // Allow create and update if the user is the owner
      allow create, update: if request.auth != null && request.auth.uid == uid;

      // Allow delete if admin
      allow delete: if isAdmin();
    }

    // Menu Category rules
    match /menuCategories/{categoryId} {
      allow create: if request.auth != null && request.resource.data.restaurantId == request.auth.uid;
      allow read: if (request.auth != null && resource.data.restaurantId == request.auth.uid) || isAdmin();
      allow update: if request.auth != null && resource.data.restaurantId == request.auth.uid;
      allow delete: if (request.auth != null && resource.data.restaurantId == request.auth.uid) || isAdmin();
    }

    // Menu Item rules
    match /menuItems/{itemId} {
      // Allow public read access for menu display
      allow read: if true || isAdmin();

      // Owner write access
      allow create: if request.auth != null && request.resource.data.restaurantId == request.auth.uid;
      allow update: if request.auth != null && resource.data.restaurantId == request.auth.uid;
      allow delete: if (request.auth != null && resource.data.restaurantId == request.auth.uid) || isAdmin();
    }

    // Order rules
    match /orders/{orderId} {
      // Anyone can create an order
      allow create: if true;

      // Only the restaurant owner or an admin can read their orders
      allow read: if (request.auth != null && resource.data.restaurantId == request.auth.uid) || isAdmin();

      // Only the restaurant owner can update the status/updatedAt, or an admin can update anything
      allow update: if (request.auth != null && resource.data.restaurantId == request.auth.uid &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']))
                    || isAdmin();

      // Only admins can delete orders
      allow delete: if isAdmin();
    }
  }
}
